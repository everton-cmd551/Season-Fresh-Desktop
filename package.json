{
  "name": "season-fresh-desktop",
  "version": "1.0.9",
  "description": "Desktop client for Season Fresh ERP — loads the live production URL with auto-updates via GitHub Releases.",
  "main": "main.js",
  "author": "Season Fresh <info@seasonfresh.co.zw>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/everton-cmd551/Season-Fresh-Desktop.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "pack": "electron-builder --dir",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-log": "^5.3.0",
    "electron-store": "^6.0.1",
    "electron-updater": "^6.3.9",
    "jimp": "^1.6.0",
    "pkg-dir": "^4.2.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.seasonfresh.erp",
    "productName": "Season Fresh",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "offline.html"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "everton-cmd551",
        "repo": "Season-Fresh-Desktop"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "shortcutName": "Season Fresh"
    }
  }
}
